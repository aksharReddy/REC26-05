# Required for Gemini embeddings and Gemini answer generation.
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_BATCH_SIZE=16
GEMINI_EMBEDDING_DELAY_SECONDS=3
GEMINI_EMBEDDING_CONTENTS_PER_MINUTE=80

# Use "gemini" for the intended API-backed pipeline, or "tfidf" for offline fallback.
EMBEDDING_PROVIDER=gemini
